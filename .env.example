# ============================================================
# SOC-AI v1.0 — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── LLM Backend ─────────────────────────────────────────────
# "claude" to use Anthropic Claude API (requires ANTHROPIC_API_KEY)
# "ollama"  to use local Ollama (recommended for sensitive/PII logs)
LLM_BACKEND=ollama

# Anthropic API key (only required when LLM_BACKEND=claude)
ANTHROPIC_API_KEY=

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Ollama service URL (Docker service name by default)
OLLAMA_HOST=http://ollama:11434

# Ollama model to pull/use (llama3.1 recommended for English+French)
OLLAMA_MODEL=llama3.1

# ── RGPD / PII ──────────────────────────────────────────────
# Anonymise IP, username, email BEFORE sending log to cloud LLM.
# Set to "false" only when using Ollama locally (no data leaves the host).
# ⚠️ WARNING: Do NOT send real PII to a cloud LLM. Use Ollama for sensitive data.
ANONYMIZE_PII=true

# Log/alert data retention in days (events and triage older than this are purged).
RETENTION_DAYS=90

# ── Database ─────────────────────────────────────────────────
# Path to SQLite database file (inside container — mount a volume to persist).
DB_PATH=/data/soc.db

# ── Parser ───────────────────────────────────────────────────
# Directory to watch for incoming log files.
LOG_DIR=/logs

# Polling interval in seconds for the SQLite bus (engine / agent loops).
POLL_INTERVAL=2

# ── API / Dashboard ──────────────────────────────────────────
# Port exposed by the FastAPI backend.
API_PORT=8000

# Vite env var: URL of the FastAPI API (seen from the browser, not the container).
VITE_API_URL=http://localhost:8000

# ── Plan / Edition ───────────────────────────────────────────
# "community" (default, open source), "pro", or "enterprise"
# Pro unlocks: Slack/Teams webhooks, MITRE heatmap, risk scores, compliance
# Enterprise adds: multi-tenant, SSO, NIS2 reports
PLAN=community

# Admin token — grants full Pro/Enterprise access regardless of PLAN.
# Set a strong random string. Never commit this value.
ADMIN_TOKEN=

# ── Notifications (Pro) ──────────────────────────────────────
# Slack incoming webhook URL (leave blank to disable)
SLACK_WEBHOOK_URL=

# Microsoft Teams incoming webhook URL (leave blank to disable)
TEAMS_WEBHOOK_URL=

# Minimum severity to trigger a notification: HIGH or CRITICAL
NOTIFY_MIN_SEVERITY=HIGH
